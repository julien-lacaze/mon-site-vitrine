---
import Layout from '../layouts/Layout.astro';
import { disponibilite } from '../config/dispo.js';
---

<Layout title="CMO Freelance B2B">

  <!-- ═══════════════════════════════════════
       HERO
  ═══════════════════════════════════════ -->
  <section style="
    min-height: 100vh;
    padding: 10rem 3rem 6rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    max-width: 1400px;
    margin: 0 auto;
  ">
    <!-- Left: texte -->
    <div>
      <span class="tag fade-up fade-up-delay-1">CMO Freelance · Bordeaux</span>
      <h1 class="fade-up fade-up-delay-2" style="
        font-size: clamp(3.2rem, 6vw, 6rem);
        margin-top: 1.5rem;
        margin-bottom: 1.5rem;
        color: var(--color-text);
      ">
        Structurer.<br/>
        <em style="color: var(--color-accent); font-style: italic;">Accélérer.</em><br/>
        Mesurer.
      </h1>
      <p class="fade-up fade-up-delay-3" style="
        font-size: 1.1rem;
        color: var(--color-muted);
        max-width: 640px;
        line-height: 1.8;
        margin-bottom: 2.5rem;
      ">
        J'aide les startups et PME à construire leur marketing de zéro.<br/>
        Stratégie → acquisition → go-to-market → mesure des résultats.<br/>
        Votre CMO externalisé, disponible rapidement.
      </p>
      <div class="fade-up fade-up-delay-4" style="display: flex; gap: 1rem; align-items: center;">
        <a href="#contact" style="
          background: var(--color-accent);
          color: var(--color-bg);
          padding: 0.85rem 2rem;
          font-size: 0.85rem;
          font-weight: 500;
          letter-spacing: 0.06em;
          text-transform: uppercase;
          border-radius: 8px;
          transition: opacity 0.2s ease;
        ">Travaillons ensemble</a>
        <a href="/clients" style="
          font-size: 0.85rem;
          color: var(--color-muted);
          letter-spacing: 0.04em;
          border-bottom: 1px solid var(--color-border);
          padding-bottom: 2px;
          transition: color 0.2s ease, border-color 0.2s ease;
        ">Voir mes missions →</a>
      </div>

      <!-- Chiffres clés -->
      <div class="fade-up fade-up-delay-4" style="
        display: flex;
        gap: 1rem;
        margin-top: 4rem;
        padding-top: 2rem;
        border-top: 1px solid var(--color-border);
      ">
        <div style="background: var(--color-surface); border: 1px solid var(--color-border); border-radius: 4px; padding: 1.5rem;">
          <p style="font-family: var(--font-display); font-size: 3rem; color: var(--color-text);">10+</p>
          <p style="font-size: 0.75rem; color: var(--color-text); letter-spacing: 0.05em; text-transform: uppercase;">ans d'expérience</p>
        </div>
        <div style="background: var(--color-surface); border: 1px solid var(--color-border); border-radius: 4px; padding: 1.5rem;">
          <p style="font-family: var(--font-display); font-size: 3rem; color: var(--color-text);">700€</p>
          <p style="font-size: 0.75rem; color: var(--color-text); letter-spacing: 0.05em; text-transform: uppercase;">TJM</p>
        </div>
        <div style="background: var(--color-surface); border: 1px solid var(--color-border); border-radius: 4px; padding: 1.5rem;">
          <p style="font-family: var(--font-display); font-size: 3rem; color: var(--color-text);">B2B</p>
          <p style="font-size: 0.75rem; color: var(--color-text); letter-spacing: 0.05em; text-transform: uppercase;">SaaS · PME · Startups</p>
        </div>
      </div>
    </div>

    <!-- Right: photo -->
    <div style="
      position: relative;
      display: flex;
      justify-content: flex-end;
    ">
      <div style="
        width: 420px;
        height: 520px;
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: 2px;
        overflow: hidden;
        position: relative;
      ">
        <img
          src="/photo-profil.jpeg"
          alt="Julien Lacaze"
          style="width: 100%; height: 100%; object-fit: cover; object-position: center top;"
        />
        <!-- Accent corner -->
        <div style="
          position: absolute;
          bottom: 0;
          left: 0;
          width: 60px;
          height: 3px;
          background: var(--color-accent);
        "></div>
      </div>
      <!-- Floating tag -->
      <div style="
        position: absolute;
        bottom: 2rem;
        right: -1rem;
        background: var(--color-bg);
        border: 1px solid var(--color-border);
        padding: 1rem 1.5rem;
        font-size: 0.8rem;
        color: var(--color-muted);
        max-width: 200px;
        line-height: 1.5;
      ">
        <span style={`color: ${disponibilite.disponible ? '#4ade80' : '#f87171'}; display:block; margin-bottom:0.25rem; font-size:0.7rem; letter-spacing:0.1em; text-transform:uppercase;`}>
          {disponibilite.disponible ? '● Disponible' : '● Indisponible'}
        </span>
        {disponibilite.disponible
          ? 'Missions CMO part-time & stratégie marketing'
          : disponibilite.prochaine_dispo
            ? `Prochaine disponibilité : ${disponibilite.prochaine_dispo}`
            : 'Actuellement en mission'}
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════
       CE QUE JE SAIS FAIRE
  ═══════════════════════════════════════ -->
  <section style="
    padding: 6rem 3rem;
    max-width: 1400px;
    margin: 0 auto;
    margin-left: 0;
    margin-right: 0;
    width: 100%;
    box-sizing: border-box;
  ">
    <div style="margin-bottom: 4rem;">
      <div class="sep"></div>
      <h2 style="font-size: clamp(2rem, 4vw, 3.2rem); margin-bottom: 1rem;">Ce que j'apporte</h2>
      <p style="color: var(--color-muted); max-width: 500px;">
        Stratégie et exécution ne vont pas l'un sans l'autre. Je m'adapte à votre
        contexte, votre niveau de maturité et vos ressources disponibles en interne.
      </p>
    </div>

    <div style="
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 1.5rem;
    ">

      <!-- Service 1 -->
      <div class="card">
        <div style="color: var(--color-accent); font-size: 1.5rem; margin-bottom: 1.2rem;">01</div>
        <h3 style="font-size: 1.3rem; margin-bottom: 0.75rem;">CMO Part-time</h3>
        <p style="color: var(--color-muted); font-size: 0.9rem; line-height: 1.7;">
          Direction marketing opérationnelle, 2 à 3 jours/semaine.<br/>
          Je construis et j'anime votre équipe marketing de l'intérieur.
        </p>
      </div>

      <!-- Service 2 -->
      <div class="card">
        <div style="color: var(--color-accent); font-size: 1.5rem; margin-bottom: 1.2rem;">02</div>
        <h3 style="font-size: 1.3rem; margin-bottom: 0.75rem;">Stratégie Go-to-Market</h3>
        <p style="color: var(--color-muted); font-size: 0.9rem; line-height: 1.7;">
          Segmentation, positionnement, canaux d'acquisition, message.<br/>
          Tester rapidement, mesurer, prendre des décisions rapides et itérer à nouveau.
        </p>
      </div>

      <!-- Service 3 -->
      <div class="card">
        <div style="color: var(--color-accent); font-size: 1.5rem; margin-bottom: 1.2rem;">03</div>
        <h3 style="font-size: 1.3rem; margin-bottom: 0.75rem;">Acquisition digitale</h3>
        <p style="color: var(--color-muted); font-size: 0.9rem; line-height: 1.7;">
          SEO, SEA, LinkedIn Ads, email marketing, automation.<br/>
          Une vision sur l'ensemble des canaux.
        </p>
      </div>

      <!-- Service 4 -->
      <div class="card" style="background: var(--color-accent-dim); border-color: rgba(212, 168, 83, 0.2);">
        <div style="color: var(--color-accent); font-size: 1.5rem; margin-bottom: 1.2rem;">04</div>
        <h3 style="font-size: 1.3rem; margin-bottom: 0.75rem;">No code</h3>
        <p style="color: var(--color-muted); font-size: 0.9rem; line-height: 1.7; margin-bottom: 1.5rem;">
          Automatisations, création de systèmes d'opération.
        </p>
        <span style="
          font-size: 0.7rem;
          font-weight: 500;
          letter-spacing: 0.1em;
          text-transform: uppercase;
          color: var(--color-muted);
          border: 1px solid var(--color-border);
          padding: 3px 10px;
          border-radius: 999px;
        ">Offre en construction</span>
      </div>

    </div>
  </section>


  <!-- ═══════════════════════════════════════
       PORTFOLIO CARROUSEL
  ═══════════════════════════════════════ -->
  <section style="
    padding: 6rem 0;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    overflow: hidden;
  ">
    <div style="padding: 0 3rem; margin-bottom: 3rem;">
      <div class="sep"></div>
      <h2 style="font-size: clamp(2rem, 4vw, 3.2rem);">Missions récentes</h2>
    </div>

    <!-- Carrousel -->
    <div id="carousel-track" style="
      display: flex;
      gap: 1.5rem;
      padding: 0 3rem;
      overflow-x: auto;
      scrollbar-width: none;
      cursor: grab;
    ">

      <!-- Carte mission 1 — à personnaliser -->
      <div style="
        min-width: 360px;
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: 2px;
        padding: 2rem;
        flex-shrink: 0;
        transition: border-color 0.3s ease;
      " class="mission-card">
        <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 1.5rem;">
          <span class="tag">CMO Part-time</span>
          <span style="font-size: 0.75rem; color: var(--color-muted);">2025–2026</span>
        </div>
        <h3 style="font-size: 1.2rem; margin-bottom: 0.75rem;">Noé</h3>
        <p style="font-size: 0.88rem; color: var(--color-muted); line-height: 1.7; margin-bottom: 1.5rem;">
          Direction marketing à temps partagé pour une startup en phase d'amorçage.
          Stratégie, acquisition, coordination des prestataires.
        </p>
        <a href="/clients#noe" style="font-size: 0.8rem; color: var(--color-accent); letter-spacing: 0.05em;">Voir la mission →</a>
      </div>

      <!-- Carte mission 2 — SNCF -->
      <div style="
        min-width: 360px;
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: 2px;
        padding: 2rem;
        flex-shrink: 0;
        transition: border-color 0.3s ease;
      " class="mission-card">
        <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 1.5rem;">
          <span class="tag">Conseil</span>
          <span style="font-size: 0.75rem; color: var(--color-muted);">2025–2026</span>
        </div>
        <h3 style="font-size: 1.2rem; margin-bottom: 0.75rem;">SNCF</h3>
        <p style="font-size: 0.88rem; color: var(--color-muted); line-height: 1.7; margin-bottom: 1.5rem;">
          Migration du bilan carbone IT vers le logiciel SaaS Sweep.
        </p>
        <a href="/clients#sncf" style="font-size: 0.8rem; color: var(--color-accent); letter-spacing: 0.05em;">Voir la mission →</a>
      </div>

      <!-- Carte mission 3 -->
      <div style="
        min-width: 360px;
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: 2px;
        padding: 2rem;
        flex-shrink: 0;
        transition: border-color 0.3s ease;
      " class="mission-card">
        <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 1.5rem;">
          <span class="tag">Email marketing</span>
          <span style="font-size: 0.75rem; color: var(--color-muted);">2026</span>
        </div>
        <h3 style="font-size: 1.2rem; margin-bottom: 0.75rem;">Coédis</h3>
        <p style="font-size: 0.88rem; color: var(--color-muted); line-height: 1.7; margin-bottom: 1.5rem;">
          Déploiement d'une stratégie emailing B2B dans le cadre de la 1ère convention professionnelle de Coédis. Salle Gaveau, Paris — mai 2026.
        </p>
        <a href="/clients#coedis" style="font-size: 0.8rem; color: var(--color-accent); letter-spacing: 0.05em;">Voir la mission →</a>
      </div>

      <!-- Carte mission 3 — Alexia.fr -->
      <div style="
        min-width: 360px;
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: 2px;
        padding: 2rem;
        flex-shrink: 0;
        transition: border-color 0.3s ease;
      " class="mission-card">
        <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 1.5rem;">
          <span class="tag">Copywriter</span>
          <span style="font-size: 0.75rem; color: var(--color-muted);">2025</span>
        </div>
        <h3 style="font-size: 1.2rem; margin-bottom: 0.75rem;">Alexia.fr</h3>
        <p style="font-size: 0.88rem; color: var(--color-muted); line-height: 1.7; margin-bottom: 1.5rem;">
          Copywriting du tunnel d'inscription et de la page d'accueil du site alexia.fr.
        </p>
        <a href="/clients#alexia" style="font-size: 0.8rem; color: var(--color-accent); letter-spacing: 0.05em;">Voir la mission →</a>
      </div>

      <!-- Carte mission 4 — Geev -->
      <div style="
        min-width: 360px;
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: 2px;
        padding: 2rem;
        flex-shrink: 0;
        transition: border-color 0.3s ease;
      " class="mission-card">
        <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 1.5rem;">
          <span class="tag">Marketing B2B</span>
          <span style="font-size: 0.75rem; color: var(--color-muted);">2024–2025</span>
        </div>
        <h3 style="font-size: 1.2rem; margin-bottom: 0.75rem;">Geev</h3>
        <p style="font-size: 0.88rem; color: var(--color-muted); line-height: 1.7; margin-bottom: 1.5rem;">
          Développement du marketing de l'offre B2B de Geev Pro : reprise par le don, comptes pro Geev.
        </p>
        <a href="/clients#geev" style="font-size: 0.8rem; color: var(--color-accent); letter-spacing: 0.05em;">Voir la mission →</a>
      </div>

    </div>
  </section>


  <!-- ═══════════════════════════════════════
       CLIENTS / LOGOS
  ═══════════════════════════════════════ -->
  <section style="
    padding: 6rem 3rem;
    max-width: 1400px;
    margin: 0 auto;
    text-align: center;
  ">
    <p style="font-size: 1.1rem; color: var(--color-text); margin-bottom: 3rem;">
      Ils m'ont fait confiance
    </p>
    <div style="
      display: flex;
      justify-content: center;
      align-items: center;
      flex-wrap: nowrap;
      gap: 0 4rem;
    " id="logos-grid">
      <img src="/logos/sncf.png" alt="SNCF" style="height: 45px; width: auto; opacity: 0.5; filter: grayscale(100%); transition: opacity 0.3s ease;" onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.5'" />
      <img src="/logos/alexia.png" alt="Alexia" style="height: 45px; width: auto; opacity: 0.45; filter: grayscale(100%) brightness(2); transition: opacity 0.3s ease;" onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.45'" />
      <img src="/logos/geev.png" alt="Geev" style="height: 45px; width: auto; opacity: 0.45; filter: grayscale(100%) brightness(2); transition: opacity 0.3s ease;" onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.45'" />
      <img src="/logos/noe.png" alt="Noé" style="height: 45px; width: auto; opacity: 0.45; filter: grayscale(100%) brightness(2); transition: opacity 0.3s ease;" onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.45'" />
      <img src="/logos/coedis.png" alt="Coédis" style="height: 45px; width: auto; opacity: 0.45; filter: grayscale(100%) brightness(2); transition: opacity 0.3s ease;" onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.45'" />
      <img src="/logos/2tonnes.png" alt="2 Tonnes" style="height: 45px; width: auto; opacity: 0.45; filter: grayscale(100%) brightness(2); transition: opacity 0.3s ease;" onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.45'" />
    </div>
  </section>


  <!-- ═══════════════════════════════════════
       2 TONNES
  ═══════════════════════════════════════ -->
  <section style="
    padding: 6rem 3rem;
    max-width: 1400px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 6rem;
    align-items: center;
    border-top: 1px solid var(--color-border);
  ">
    <div>
      <div class="sep"></div>
      <h2 style="font-size: clamp(2rem, 4vw, 3.2rem); margin-bottom: 1.5rem;">
        Au-delà du marketing
      </h2>
      <p style="color: var(--color-muted); line-height: 1.8; margin-bottom: 1rem;">
        Depuis 2022, j'anime l'atelier 2 Tonnes — un atelier de sensibilisation
        qui aide les individus, les entreprises et les collectivités à comprendre
        leur rôle concret dans la décarbonation.
      </p>
      <p style="color: var(--color-muted); line-height: 1.8;">
        Pas pour donner bonne conscience. Pour que les gens repartent avec
        des leviers réels et l'envie de s'en saisir.
      </p>
    </div>

    <div style="
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: 2px;
      padding: 2.5rem;
    ">
      <img src="/logos/2tonnes.png" alt="2 Tonnes" style="height: 36px; width: auto; margin-bottom: 2rem; opacity: 0.9;" />

      <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1.5rem; margin-bottom: 2rem;">
        <div>
          <p style="font-family: var(--font-display); font-size: 2.5rem; color: var(--color-text); line-height: 1;">70</p>
          <p style="font-size: 0.75rem; color: var(--color-muted); letter-spacing: 0.08em; text-transform: uppercase; margin-top: 0.25rem;">ateliers animés</p>
        </div>
        <div>
          <p style="font-family: var(--font-display); font-size: 2.5rem; color: var(--color-text); line-height: 1;">700+</p>
          <p style="font-size: 0.75rem; color: var(--color-muted); letter-spacing: 0.08em; text-transform: uppercase; margin-top: 0.25rem;">personnes sensibilisées</p>
        </div>
        <div>
          <p style="font-family: var(--font-display); font-size: 2.5rem; color: var(--color-text); line-height: 1;">2022</p>
          <p style="font-size: 0.75rem; color: var(--color-muted); letter-spacing: 0.08em; text-transform: uppercase; margin-top: 0.25rem;">depuis</p>
        </div>
      </div>

      <div style="border-top: 1px solid var(--color-border); padding-top: 1.5rem; margin-bottom: 1.5rem;">
        <p style="font-size: 0.75rem; color: var(--color-muted); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 1rem;">Références</p>
        <p style="font-size: 0.85rem; color: var(--color-muted); line-height: 1.8;">
          France Travail Nouvelle-Aquitaine · Agglomération d'Agen ·
          Mairie de Bègles · Mairie de Bruges · CNFPT ·
          Agence de Développement et d'Innovation de Nouvelle-Aquitaine ·
          Agropole · APEC Bordeaux
        </p>
      </div>

      <a href="https://www.2tonnes.org" target="_blank" style="
        font-size: 0.8rem;
        color: var(--color-accent);
        letter-spacing: 0.05em;
      ">En savoir plus sur l'atelier 2 Tonnes →</a>
    </div>
  </section>


  <!-- ═══════════════════════════════════════
       CONTACT
  ═══════════════════════════════════════ -->
  <section id="contact" style="
    padding: 8rem 3rem;
    border-top: 1px solid var(--color-border);
    max-width: 1400px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
    align-items: start;
  ">
    <div>
      <div class="sep"></div>
      <h2 style="font-size: clamp(2rem, 4vw, 3.2rem); margin-bottom: 1.5rem;">
        On en parle ?
      </h2>
      <p style="color: var(--color-muted); line-height: 1.8; margin-bottom: 2rem;">
        Vous avez un problème de croissance, de positionnement ou d'acquisition.
        Vous cherchez une personne opérationnelle tout de suite, capable de créer et déployer une stratégie
        autant que mettre les mains dedans.
      </p>
      <p style="color: var(--color-muted); line-height: 1.8; margin-bottom: 2.5rem;">
        Je vous réponds sous 48h.
      </p>
      <div style="display: flex; flex-direction: column; gap: 0.75rem;">
        <a href="https://www.linkedin.com/in/julien-lacaze/" target="_blank" style="display:flex; align-items:center; gap:0.5rem; font-size:0.85rem; color:var(--color-text);">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          LinkedIn
        </a>
        <a href="https://www.malt.fr/profile/julienlacaze" target="_blank" style="display:flex; align-items:center; gap:0.5rem; font-size:0.85rem; color:var(--color-text); margin-top:0.75rem;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
